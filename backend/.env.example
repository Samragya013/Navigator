# Environment Variables Configuration
# Copy this file to .env and fill in your actual values
# SECURITY: Never commit .env to version control (it's in .gitignore)

# Server Configuration
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ========================================
# FIREBASE CONFIGURATION
# ========================================
# Web App Configuration (from Firebase Console)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_API_KEY=your-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id
FIREBASE_MEASUREMENT_ID=your-measurement-id

# Firebase Admin SDK Service Account (from Firebase Console > Project Settings > Service Accounts)
# Download the JSON key and copy it here, or set individual fields below
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"..."}

# OR use individual fields (for development)
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# Distance API Configuration
# OpenRouteService API (FREE - Recommended, No key required for basic usage)
OPENROUTE_ENABLED=true
OPENROUTE_API_KEY=

# MongoDB Configuration (If not using Firebase)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname
USE_MONGODB=false

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

